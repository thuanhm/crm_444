# Các biến KV_REST_API_URL và KV_REST_API_TOKEN được Vercel tự động
# thêm vào khi bạn gắn Vercel KV Database vào project (không cần tự điền
# khi deploy trên Vercel). Chỉ cần điền thủ công nếu chạy thử ở máy local
# và đã tạo KV store rồi copy giá trị từ Vercel Dashboard > Storage > .env.local tab.
KV_REST_API_URL=
KV_REST_API_TOKEN=
